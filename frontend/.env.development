# Frontend environment variables for development
# These are automatically loaded by Vite when prefixed with VITE_

# Development mode - uses Vite dev server proxies
VITE_API_BASE_URL=http://localhost/api/v1

# Individual service URLs (if service proxies are not used)
VITE_AUTH_SERVICE=http://localhost:8001/api/v1/auth
VITE_PRODUCT_SERVICE=http://localhost:8002/api/v1/products
VITE_INVENTORY_SERVICE=http://localhost:8003/api/v1/inventory
VITE_TRANSACTION_SERVICE=http://localhost:8004/api/v1/transactions
VITE_ANALYTICS_SERVICE=http://localhost:8005/api/v1/analytics
VITE_RESOURCE_SERVICE=http://localhost:8006/api/v1/resources
VITE_NOTIFICATION_SERVICE=http://localhost:8007/api/v1/notifications

# Development flags
VITE_DEBUG=true
