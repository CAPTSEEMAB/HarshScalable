# ============================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your production values
# DO NOT commit .env to version control
# ============================================================

# ------AWS CREDENTIALS------
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# ------ENVIRONMENT------
ENVIRONMENT=production
# Options: development, staging, production

# ------JWT & SECURITY------
# Store JWT secret in AWS Secrets Manager in production
# This value is only used if AWS Secrets Manager is unavailable
JWT_SECRET_KEY=your-super-secret-key-here-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------FRONTEND------
FRONTEND_URL=https://your-domain.com
FRONTEND_PORT=3000
# For development: http://localhost:5173
# For production: https://your-domain.com

# ------API CONFIGURATION------
API_BASE_URL=https://api.your-domain.com
# For docker internal: http://auth-service:8001
# For external: https://api.your-domain.com/auth

# ------SERVICE PORTS------
AUTH_SERVICE_PORT=8001
PRODUCT_SERVICE_PORT=8002
INVENTORY_SERVICE_PORT=8003
TRANSACTION_SERVICE_PORT=8004
ANALYTICS_SERVICE_PORT=8005
RESOURCE_SERVICE_PORT=8006
NOTIFICATION_SERVICE_PORT=8007

# ------CORS CONFIGURATION------
ALLOWED_ORIGINS=https://your-domain.com,https://api.your-domain.com
# Multiple origins separated by commas
# Example: https://app.example.com,https://api.example.com,https://admin.example.com

# ------DYNAMODB CONFIGURATION------
# Leave blank for AWS managed DynamoDB
# These are only needed for local development with DynamoDB Local
DYNAMODB_ENDPOINT=
SQS_ENDPOINT=
S3_ENDPOINT=

# DynamoDB Table Names
USERS_TABLE=InventoryUsers
PRODUCTS_TABLE=InventoryProducts
CATEGORIES_TABLE=InventoryCategories
WAREHOUSES_TABLE=InventoryWarehouses
INVENTORY_TABLE=InventoryStock
INVENTORY_HISTORY_TABLE=InventoryStockHistory
TRANSACTIONS_TABLE=InventoryTransactions
NOTIFICATIONS_TABLE=InventoryNotifications

# ------SQS QUEUE CONFIGURATION------
# Queue URLs from AWS console
STOCK_EVENTS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/inventory-stock-events
TRANSACTION_EVENTS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/inventory-transaction-events
NOTIFICATION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/inventory-notifications

# ------S3 CONFIGURATION------
S3_BUCKET_FRONTEND=inventory-frontend-prod
S3_BUCKET_DATA=inventory-data-prod

# ------REDIS CONFIGURATION------
# For production, use ElastiCache or similar managed service
REDIS_HOST=your-elasticache-endpoint.ng.0001.use1.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
# Optional: use Redis SSL
REDIS_SSL=true

# ------EMAIL CONFIGURATION------
# SES (Simple Email Service)
SES_SENDER_EMAIL=noreply@your-domain.com
SES_REGION=us-east-1

# SNS (Simple Notification Service)
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:inventory-alerts

# ------NOTIFICATION SETTINGS------
NOTIFICATION_POLL_INTERVAL=15
# Interval (seconds) for checking SQS notification queue

# ------ANALYTICS & ML------
ANALYTICS_CACHE_TTL=300
# Cache duration in seconds for analytics queries

# ------LOGGING------
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ------SECRETS MANAGER------
JWT_SECRET_NAME=inventory-jwt-secret
# Name of the secret in AWS Secrets Manager storing JWT key
# If not set, falls back to JWT_SECRET_KEY environment variable
# Secret should be a JSON object: {"jwt_secret": "your-key-here"}

# ------OPTIONAL: LOCAL DEVELOPMENT OVERRIDES------
# These are automatically set by .env.development
# Don't set these in production .env
DEBUG=false

# ------MONITORING & OBSERVABILITY------
CLOUDWATCH_LOG_GROUP=inventory-service-logs
# CloudWatch Log Group for centralized logging

# ------PERFORMANCE------
WORKER_THREADS=4
# Number of Uvicorn worker threads per service
DB_POOL_SIZE=20
# Database connection pool size

# ------MISC------
SERVICE_VERSION=1.0.0
BUILD_TIMESTAMP=2026-03-18
